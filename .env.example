# ── Environment Variables Template ──────────────────────────────────────────
# Copy this file to .env and fill in real values
# ⚠️ NEVER commit .env or .env.staging to git

PORT=3000
NODE_ENV=development

# JWT — use a strong random secret in production
JWT_SECRET=your-super-secret-key-here
JWT_EXPIRES_IN=30d

# Database — Neon PostgreSQL (https://neon.tech → New Project → Connection String)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Cloudinary — Image storage (https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Thunder Slip Verify API (https://api.thunder.in.th)
THUNDER_API_KEY=your-thunder-api-key
THUNDER_API_URL=https://api.thunder.in.th/v2/verify/bank

# PromptPay ID (phone number or TaxID)
PROMPTPAY_ID=0812345678

# LINE Messaging API (https://developers.line.biz)
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# Email (Gmail App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_APP_PASSWORD=your-app-password

# Payment Settings
PAYMENT_QR_EXPIRY_HOURS=24
PAYMENT_AUTO_CONFIRM=true
