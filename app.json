{
  "expo": {
    "name": "หมูนุ่น-เป๋าตุง",
    "slug": "expense-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/logo-moonoon-paotung-padded.png",
    "scheme": ["expensetracker", "poatung"],
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash/logo-moonoon-paotung-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.sevendog.poatung",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo/logo-moonoon-paotung-padded.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/splash/logo-moonoon-paotung-splash.png",
          "imageWidth": 192,
          "resizeMode": "contain",
          "android": {
            "backgroundColor": "#FFFFFF",
            "image": "./assets/splash/logo-moonoon-paotung-splash-android.png",
            "imageWidth": 192,
            "resizeMode": "contain"
          }
        }
      ],
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-local-authentication",
      "expo-document-picker",
      "expo-notifications",
      [
        "expo-camera",
        {
          "cameraPermission": "อนุญาตให้แอป Poatung เข้าถึงกล้องเพื่อสแกนสลิป"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "อนุญาตให้แอป Poatung เข้าถึงรูปภาพเพื่อเลือกสลิป"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b0f013ae-4a1d-4bfc-bbcb-a5a8962d96d4"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b0f013ae-4a1d-4bfc-bbcb-a5a8962d96d4"
    }
  }
}
